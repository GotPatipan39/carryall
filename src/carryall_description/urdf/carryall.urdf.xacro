<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="carryall">

  <!-- ==================== PROPERTIES ==================== -->
  <xacro:property name="wheel_radius" value="0.125"/>    <!-- Matching plc_params.yaml -->
  <xacro:property name="wheel_width" value="0.08"/>
  <xacro:property name="wheelbase" value="0.85"/>       <!-- Matching plc_params.yaml -->
  <xacro:property name="base_length" value="1.2"/>
  <xacro:property name="base_width" value="0.6"/>
  <xacro:property name="base_height" value="0.3"/>
  <xacro:property name="base_mass" value="50.0"/>

  <!-- ==================== BASE LINK ==================== -->
  <!-- We place base_link at the center of the REAR AXLE -->
  <link name="base_link">
    <visual>
      <origin xyz="${base_length/2 - 0.2} 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ==================== FRONT STEER & DRIVE WHEEL ==================== -->
  
  <!-- Steering Pivot -->
  <link name="front_steer_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="front_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_steer_link"/>
    <origin xyz="${wheelbase} 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="1.0" lower="-1.57" upper="1.57"/>
  </joint>

  <!-- Drive Wheel -->
  <link name="front_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="front_wheel_joint" type="continuous">
    <parent link="front_steer_link"/>
    <child link="front_wheel"/>
    <origin xyz="0 0 ${-0.1 + wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ==================== REAR WHEELS (PASSIVE) ==================== -->
  
  <!-- Rear Left -->
  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius/2}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="rear_left_joint" type="fixed">
    <parent link="base_link"/>
    <child name="rear_left_wheel"/>
    <origin xyz="0 ${base_width/2} ${wheel_radius/2}" rpy="0 0 0"/>
  </joint>

  <!-- Rear Right -->
  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius/2}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="rear_right_joint" type="fixed">
    <parent link="base_link"/>
    <child name="rear_right_wheel"/>
    <origin xyz="0 ${-base_width/2} ${wheel_radius/2}" rpy="0 0 0"/>
  </joint>

  <xacro:include filename="$(find carryall_description)/urdf/sensors.xacro"/>

</robot>
